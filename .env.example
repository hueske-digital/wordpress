# Caddy Autodiscovery
CADDY_DOMAIN=wordpress.example.com
CADDY_TYPE=external
CADDY_PORT=80
CADDY_TLS=true
CADDY_COMPRESSION=true
CADDY_HEADER=true
CADDY_PERFORMANCE=true
CADDY_SECURITY=true
CADDY_SEO=true
CADDY_WWW_REDIRECT=true
CADDY_WORDPRESS=true
CADDY_LOGGING=false

# Database
MARIADB_VERSION=
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_ROOT_PASSWORD=
DB_NAME=

# WordPress
WORDPRESS_CRON_SCHEDULE=
WORDPRESS_UPDATE_SCHEDULE=
WORDPRESS_UPDATE_PLUGIN_PARAMS=
WORDPRESS_UPDATE_THEME_PARAMS=
WORDPRESS_DISABLE_NINJAFIREWALL=

# Backup
BACKUP_CRON_SCHEDULE=

# PHP-FPM
PHP_FPM_PM_MODE=
PHP_FPM_PM_MAX_CHILDREN=
PHP_FPM_PM_START_SERVERS=
PHP_FPM_PM_MIN_SPARE_SERVERS=
PHP_FPM_PM_MAX_SPARE_SERVERS=
PHP_FPM_PM_MAX_REQUESTS=

# MariaDB Performance
MARIADB_INNODB_BUFFER_SIZE=
MARIADB_MAX_CONNECTIONS=
MARIADB_TMP_TABLE_SIZE=
MARIADB_MAX_HEAP_TABLE_SIZE=

# Resource Limits (Schadensbegrenzung, z.B. bei Bot-Last)
# Defaults = Standard-Projekt. Grosse Projekte hier hochsetzen, z.B.
# LIMIT_APP_MEM=2.5G LIMIT_APP_CPUS=4 LIMIT_DB_MEM=1G LIMIT_DB_CPUS=2
# Hinweis: app-Mem sollte >= realistischer Last aus PHP_FPM_PM_MAX_CHILDREN x memory_limit liegen,
# db-Mem deutlich > MARIADB_INNODB_BUFFER_SIZE.
LIMIT_APP_CPUS=2
LIMIT_APP_MEM=1G
LIMIT_APP_PIDS=256
LIMIT_WEB_CPUS=1
LIMIT_WEB_MEM=192M
LIMIT_WEB_PIDS=128
LIMIT_DB_CPUS=1.5
LIMIT_DB_MEM=768M
LIMIT_DB_PIDS=256

# SSH
SSH_USERNAME=
SSH_PORT=

# Docker Compose
COMPOSE_PROFILES=
PERL5LIB=/usr/lib/perl5/vendor_perl/aarch64-linux-thread-multi

# SMTP
SMTP_USER=
SMTP_PASS=
SMTP_FROM=